# ── EasyCart Backend — Environment Variables ──────────────────
# Copy this file to .env and fill in your values
# NEVER commit the actual .env file to GitHub!

# MySQL Database
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_mysql_password_here
DB_NAME=easycart

# JWT Secret — change this to a long random string in production
JWT_SECRET=easycart_super_secret_change_this_in_production_abc123

# Server port
PORT=5000
